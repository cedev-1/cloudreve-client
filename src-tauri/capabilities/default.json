{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Cloudreve desktop",
  "windows": ["main", "main_popup", "add-drive", "settings"],
  "permissions": [
    "core:default",
    "core:app:default",
    "core:window:default",
    "core:webview:default",
    "core:menu:default",
    "core:tray:default",
    "core:path:default",
    "core:event:default",
    "core:image:default",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "http://**" }, { "url": "https://**" }]
    },
    "dialog:default",
    "os:default",
    "notification:default",
    "autostart:default",
    "deep-link:default",
    "positioner:default"
  ]
}
