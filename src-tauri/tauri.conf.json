{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cloudreve",
  "version": "0.2.0-beta.1",
  "identifier": "cloudreve.desktop",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "yarn run dev",
    "beforeBuildCommand": "yarn run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cloudreve",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": [
            "**/*"
          ]
        }
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "cloudreve"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFOTRGRjJFNEU3QTNBMDEKUldRQk9ucE9MditVWHFTaUl4S3B6eEZYdDJETlVPNzVxUUk5Rm1JK1BHRHNiMG11WGw1ZnlkRVIK",
      "endpoints": [
        "https://github.com/cedev-1/cloudreve-client/releases/latest/download/latest.json"
      ]
    }
  }
}
